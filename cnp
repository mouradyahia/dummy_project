def list_projects_in_lab(lab_folder_id):
    import dataiku
    client = dataiku.api_client()
    lab_folder = client.get_project_folder(lab_folder_id)
    return [
        {"id": sub.project_folder_id, "label": sub.get_name()}
        for sub in lab_folder.list_child_folders()
    ]
