            ng-if="nameCheck.message"
            ng-style="{color: nameCheck.ok ? 'green' : '#c9302c'}">
        {{ nameCheck.message }}
      </span>
    </div>
  </div>

</div>










var app = angular.module('myplugin.projectForm', []);

app.controller('ProjectFormController', function($scope) {

    $scope.choices = { domain: [], lab: [], owner_id: [] };
    $scope.nameCheck = { ok: null, message: "" };

    // --- Load dropdown choices ---
    function loadChoices(paramName) {
        $scope.callPythonDo({ parameterName: paramName }).then(function(data) {
            $scope.choices[paramName] = data.choices || [];
        }, function(err) {
            console.error("Failed to load " + paramName, err);
            $scope.choices[paramName] = [];
        });
    }

    loadChoices("domain");
    loadChoices("lab");
    loadChoices("owner_id");

    // If owner depends on lab, reload owners when lab changes
    $scope.$watch("config.lab", function(newVal, oldVal) {
        if (newVal !== oldVal) {
            $scope.config.owner_id = null;
            loadChoices("owner_id");
        }
    });

    // --- Debounced name collision check ---
    var debounceTimer = null;
    $scope.onNameChange = function() {
        if (debounceTimer) clearTimeout(debounceTimer);
        $scope.nameCheck = { ok: null, message: "Checking..." };

        debounceTimer = setTimeout(function() {
            $scope.callPythonDo({ parameterName: "__check_name" }).then(function(data) {
                $scope.$apply(function() {
                    $scope.nameCheck = {
                        ok: data.ok,
                        message: data.message
                    };
                });
            }, function(err) {
                $scope.$apply(function() {
                    $scope.nameCheck = { ok: false, message: "Check failed" };
                });
            });
        }, 300); // 300ms debounce
    };
});



from project_data import (
    list_domains, list_labs, list_owners, list_existing_project_names
)

def _as_choices(items):
    return [{"value": i["id"], "label": i["label"]} for i in items]

def do(payload, config, plugin_config, inputs):
    param = payload.get("parameterName")

    if param == "domain":
        return {"choices": _as_choices(list_domains())}

    if param == "lab":
        return {"choices": _as_choices(list_labs())}

    if param == "owner_id":
        # cascading example: filter owners by selected lab
        owners = list_owners()
        # lab = config.get("lab")
        # if lab: owners = [o for o in owners if o.get("lab") == lab]
        return {"choices": _as_choices(owners)}

    if param == "__check_name":
        name = (config.get("project_name") or "").strip()
        if not name:
            return {"ok": None, "message": ""}
        existing = {n.lower() for n in list_existing_project_names()}
        if name.lower() in existing:
            return {"ok": False, "message": "Name already exists"}
        return {"ok": True, "message": "Available"}

    return {"choices": []}




