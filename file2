<div ng-controller="ProjectFormController" style="margin: 10px 0">

  <!-- Domain -->
  <div class="control-group">
    <label class="control-label">Domain</label>
    <div class="controls">
      <select dku-bs-select="{liveSearch:true}"
              ng-model="config.domain"
              ng-options="c.value as c.label for c in choices.domain">
        <option value="">— select a domain —</option>
      </select>
    </div>
  </div>

  <!-- Lab -->
  <div class="control-group">
    <label class="control-label">Lab</label>
    <div class="controls">
      <select dku-bs-select="{liveSearch:true}"
              ng-model="config.lab"
              ng-options="c.value as c.label for c in choices.lab">
        <option value="">— select a lab —</option>
      </select>
    </div>
  </div>

  <!-- Owner -->
  <div class="control-group">
    <label class="control-label">Owner</label>
    <div class="controls">
      <select dku-bs-select="{liveSearch:true}"
              ng-model="config.owner_id"
              ng-options="c.value as c.label for c in choices.owner_id">
        <option value="">— select an owner —</option>
      </select>
    </div>
  </div>

  <!-- Project name with collision check -->
  <div class="control-group">
    <label class="control-label">Project name</label>
