var app = angular.module('myplugin.projectForm', []);

app.controller('ProjectFormController', function($scope) {
    var PROJECT_KEY_RE = /^[A-Za-z][A-Za-z0-9_]{0,31}$/;

    $scope.validation = { ok: null, message: "" };

    $scope.validateName = function() {
        var name = ($scope.config || {}).project_name || "";
        if (!name) {
            $scope.validation = { ok: null, message: "" };
        } else if (name.length > 32) {
            $scope.validation = { ok: false, message: "Too long (max 32 chars)" };
        } else if (!/^[A-Za-z]/.test(name)) {
            $scope.validation = { ok: false, message: "Must start with a letter" };
        } else if (!PROJECT_KEY_RE.test(name)) {
            $scope.validation = { ok: false, message: "Only letters, digits and underscores allowed" };
        } else {
            $scope.validation = { ok: true, message: "Valid ✓" };
        }
    };
});







